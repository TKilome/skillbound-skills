{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "build_image",
  "type": "object",
  "required": ["deploymentTarget", "baseImage", "localJar", "targetImage"],
  "properties": {
    "deploymentTarget": {
      "type": "string",
      "const": "kubernetes",
      "description": "Provider selector. build_image currently prepares Kubernetes-oriented Flink application images."
    },
    "baseImage": {"type": "string", "minLength": 1},
    "localJar": {"type": "string", "minLength": 1},
    "targetImage": {"type": "string", "minLength": 1},
    "targetJarPath": {"type": "string", "minLength": 1},
    "confirm": {"type": "boolean"},
    "dryRun": {"type": "boolean"}
  },
  "additionalProperties": false
}
