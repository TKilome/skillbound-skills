[
  {
    "name": "k8s_start_job schema has explicit Kubernetes fields",
    "file": "schemas/k8s_start_job.schema.json",
    "expected_values": ["name", "namespace", "serviceAccount", "flinkImage", "jarUri", "parallelism"]
  },
  {
    "name": "skill yaml marks provider status",
    "file": "skill.yaml",
    "expected_values": ["kubernetes: implemented", "yarn: implemented"]
  },
  {
    "name": "inspection schemas are registered",
    "file": "skill.yaml",
    "expected_values": ["inspect_cluster", "diagnose_backpressure"]
  },
  {
    "name": "read-back and target lock schema fields are available",
    "file": "schemas/stop_job.schema.json",
    "expected_values": ["verify", "expectedTargetLock"]
  },
  {
    "name": "runtime docs do not reference legacy kubernetes provider path",
    "forbidden_legacy_provider_path": true
  }
]
