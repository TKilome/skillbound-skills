[
  {
    "name": "preview start manifest",
    "command": "k8s_start_job --name orders --namespace data-flink --service-account data-flink --flink-image flink:1.19 --jar-uri local:///opt/flink/usrlib/orders.jar --parallelism 4 --confirm --dry-run",
    "expected_success": true
  },
  {
    "name": "preview build image",
    "command": "k8s_build_image --base-image flink:1.19.3-scala_2.12-java11 --local-jar /tmp/orders.jar --target-image orders-flink:dev --target-jar-path /opt/flink/usrlib/orders.jar --confirm --dry-run",
    "expected_success": true
  },
  {
    "name": "preview status command",
    "command": "get_job_status --job-manager-url http://jm:8081 --job-id job-1 --dry-run",
    "expected_success": true
  },
  {
    "name": "preview status through ingress nodeport with host header",
    "command": "get_job_status --job-manager-url http://127.0.0.1:31626 --job-id job-1 --http-host-header topspeed-windowing.flink.k8s.com --dry-run",
    "expected_success": true,
    "expected_host_header": "topspeed-windowing.flink.k8s.com"
  },
  {
    "name": "preview kubernetes node ip query",
    "command": "k8s_get_node_ips --dry-run",
    "expected_success": true
  },
  {
    "name": "preview yarn application start",
    "command": "start_job --deployment-target yarn --name orders --flink-home /opt/flink --flink-version 1.19.1 --jar-uri hdfs:///apps/orders.jar --parallelism 4 --yarn-queue production --confirm --dry-run",
    "expected_success": true,
    "expected_provider": "yarn",
    "expected_deployment_target": "yarn-application"
  },
  {
    "name": "unknown provider reports unsupported provider",
    "command": "start_job --deployment-target standalone --name orders --jar-uri file:///apps/orders.jar --parallelism 4 --confirm --dry-run",
    "expected_success": false,
    "expected_error_code": "UnsupportedProvider"
  },
  {
    "name": "kubernetes example start must use skill cli only",
    "prompt": "帮我在k8s上启动一个flink example下的实时任务",
    "forbidden_tools": ["kubectl", "flink run-application", "$FLINK_HOME/bin/flink"],
    "expected_behavior": "ask for missing name, namespace, service-account, flink-image, FLINK_HOME, and confirmation before executing"
  },
  {
    "name": "kubernetes start must wait for command confirmation",
    "prompt": "用 name=orders namespace=data-flink serviceAccount=data-flink image=flink:1.19.3-scala_2.12-java11 FLINK_HOME=/Users/example/soft/flink-1.19.3 启动 TopSpeedWindowing",
    "forbidden_before_confirmation": ["--confirm"],
    "expected_behavior": "show final FlinkOpsCli command and wait for explicit user confirmation"
  }
]
